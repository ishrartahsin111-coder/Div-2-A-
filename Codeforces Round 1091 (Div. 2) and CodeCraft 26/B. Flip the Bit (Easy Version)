#include<bits/stdc++.h>
using namespace std;
int main(){
   int t;
   cin>>t;
   while(t--){
    int n,k;
    cin>>n>>k;
    vector<int>a(n),p(k);
    for(int i=0;i<n;i++)  cin>>a[i];
    int idx;
    cin>>idx;
    int cnt1=0;
    int cnt2=0;
    for(int i=0;i<idx-1;i++){
        if(a[i]!=a[i+1]){
            cnt1++;
        }
    }
    if(cnt1%2==1) cnt1++;
    for(int i=idx-1;i<n-1;i++){
        if(a[i]!=a[i+1]) cnt2++;
    }
    if(cnt2%2==1) cnt2++;

    cout<<max(cnt1,cnt2)<<endl;

   }



}
